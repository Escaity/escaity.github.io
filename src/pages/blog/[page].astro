---
import PostView from '../../components/PostView.astro'
import IndexPage from '../../layouts/IndexPage.astro'
import Pagination from '../../components/Pagination.astro';
import {getBlogPosts} from "../../utils/posts";
import {getPaginatedBlogPosts} from "../../utils/getPaginatedBlogPosts";

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  const {totalPage, getPagePosts} = getPaginatedBlogPosts(posts);

  return Array.from({length: Math.max(totalPage - 1, 0)}, (_, index) => {
    const pageNumber = index + 2;

    return {
      params: {page: String(pageNumber)},
      props: {
        page: {
          currentPage: pageNumber,
          lastPage: totalPage,
          data: getPagePosts(pageNumber),
        },
      },
    };
  });
}

// 所有分页数据都将传递给 "page" 参数
const {page} = Astro.props;
---


<IndexPage frontmatter={{comment:false}}>
  {
    page.data.map((blog, index) =>
      <PostView blog={blog}></PostView>)
  }
  <Pagination
    currentPage={page.currentPage}
    totalPage={page.lastPage}
    prefixUrl="/blog/"
    firstPageHref="/"
  />
</IndexPage>
