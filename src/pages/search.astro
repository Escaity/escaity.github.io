---
import IndexPage from "src/layouts/IndexPage.astro";
import {Search} from '../components/Search'
import {getBlogPosts} from "../utils/posts";
const posts = (await getBlogPosts()).map(({collection, id, data}) => ({
  collection,
  id,
  data: {
    title: data.title,
    description: data.description,
    date: data.date,
    category: data.category,
    tags: data.tags,
  },
}));
---

<IndexPage>
  <div class="text-2xl mb-4 text-skin-base">検索</div>
  <Search client:only="solid-js" posts={posts}/>
</IndexPage>
