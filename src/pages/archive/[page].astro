---
import IndexPage from "src/layouts/IndexPage.astro";
import Pagination from "src/components/Pagination.astro";
import { sortPostsByDate } from "src/utils/sortPostsByDate";
import  {site} from "../../consts";
import { getBlogPosts } from "../../utils/posts";
import ArchiveList from "src/components/ArchiveList.astro";
export async function getStaticPaths({ paginate }) {
  let posts = await getBlogPosts();
  posts = sortPostsByDate(posts);
  return paginate(posts, { pageSize: site.archivePageSize });
}
// 所有分页数据都将传递给 "page" 参数
const { page } = Astro.props;
---

<IndexPage>
  <ArchiveList posts={page.data}/>
  <Pagination
    currentPage={page.currentPage}
    totalPage={page.lastPage}
    prefixUrl="/archive/"
    url={page.slug}
  />
</IndexPage>
