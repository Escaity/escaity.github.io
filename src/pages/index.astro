---
import PostView from '../components/PostView.astro'
import IndexPage from '../layouts/IndexPage.astro'
import {getBlogPosts} from "../utils/posts";
import Pagination from "../components/Pagination.astro";
import {getPaginatedBlogPosts} from "../utils/getPaginatedBlogPosts";

const blogs = await getBlogPosts();
const {totalPage, firstPagePosts} = getPaginatedBlogPosts(blogs);
---

<IndexPage>
  {
    firstPagePosts.map(blog =>
      <PostView blog={blog}></PostView>)
  }
  {
    totalPage > 1 ?
      <Pagination
        currentPage={1}
        totalPage={totalPage}
        prefixUrl="/blog/"
        firstPageHref="/"
      /> : ''
  }
</IndexPage>
