---
import dayjs from "dayjs";
import getPostsByYear from "src/utils/getPostsByYear";

const {posts, titleHover = true} = Astro.props;
const resultPosts = getPostsByYear(posts);
const archiveAnchors = new Set();
const getArchiveAnchor = (date) => {
  const key = dayjs(date).format("YYYY-MM");
  if (archiveAnchors.has(key)) return undefined;
  archiveAnchors.add(key);
  return `archive-${key}`;
};
---

{
  Object.keys(resultPosts)
    .sort((a, b) => Number(b) - Number(a))
    .map((year) => (
      <div>
        <div class="text-2xl font-extrabold my-4">{year}</div>
        <ul>
          {resultPosts[year].map((post) => (
            <li id={getArchiveAnchor(post.data.date)} style="list-style-type: disc;" class="ml-4 my-2">
              <a href={'/' + post.collection + '/' + post.id}>
                <span class="mr-4">
                  {dayjs(post.data.date).format("YYYY-MM-DD")}
                </span>
                {
                  titleHover ? (
                    <span class="hover:text-skin-active">
                      {post.data.title}
                    </span>
                  ) : (
                    post.data.title
                  )
                }
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))
}
