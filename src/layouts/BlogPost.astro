---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Profile from '../components/Profile.astro'
import Toc from '../components/Toc.astro'
import ScrollToTop from '../components/ScrollToTop.astro'
import PageAnalytics from '../components/PageAnalytics.astro'
const {frontmatter = {comment: false, donate: false, toc: false, mathjax: false, mermaid: false}} = Astro.props
---

<html lang="ja">
<BaseHead mathjax={frontmatter.mathjax} mermaid={frontmatter.mermaid}/>

<body class="bg-skin-secondary">
<Header/>
<main class="container p-4  pt-20 text-skin-base min-h-full pb-32 relative" id="app">
  <div class="grid grid-cols-4 gap-8">
    <div id="sidebar" class="hidden xl:block col-span-1 relative">
      <Profile></Profile>
      {
        frontmatter.toc &&
        <Toc></Toc>
      }
    </div>
    <div class="col-span-4 xl:col-span-3 space-y-4">
      <slot/>
    </div>
    <ScrollToTop></ScrollToTop>
  </div>
  <Footer/>
</main>
<PageAnalytics/>
</body>
</html>

<script>
  import fancyboxStylesUrl from "@fancyapps/ui/dist/fancybox/fancybox.css?url";

  // 给所有的a标签添加target属性和不追踪
  const markdownBody = document.querySelector(".markdown-body");
  // 如果没有markdownBody则直接返回
  if (markdownBody) {
    const images = markdownBody.querySelectorAll("img[data-fancybox]");
    if (images.length > 0) {
      let fancyboxReady = false;
      let fancyboxLoading;
      const loadFancybox = async () => {
        if (fancyboxReady) return;
        if (!fancyboxLoading) {
          fancyboxLoading = (async () => {
            if (!document.querySelector(`link[href="${fancyboxStylesUrl}"]`)) {
              const link = document.createElement("link");
              link.rel = "stylesheet";
              link.href = fancyboxStylesUrl;
              document.head.append(link);
            }
            const {Fancybox} = await import("@fancyapps/ui");
            Fancybox.bind("[data-fancybox]");
            fancyboxReady = true;
          })();
        }
        await fancyboxLoading;
      };

      images.forEach((image) => {
        image.addEventListener("click", async (event) => {
          if (fancyboxReady) return;
          event.preventDefault();
          event.stopPropagation();
          await loadFancybox();
          image.click();
        }, {once: true});
      });
    }

    var links = markdownBody.querySelectorAll("a");
    // 循环遍历链接标签
    for (var i = 0; i < links.length; i++) {
      // 给每个链接标签添加 target 属性
      let names = links[i].getAttributeNames()
      if (!names.includes('data-footnote-backref') && !names.includes('data-footnote-ref')) {
        links[i].setAttribute("target", "_blank");
        links[i].setAttribute("rel", "nofollow noreferrer");
      }
    }
  }
</script>
